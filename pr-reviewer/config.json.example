{
  "reviewer_username": "github_username",
  "llm": {
    "backend": "opencode",
    "_comment_backend": "Backends: 'opencode' (default), 'claude', 'gemini', 'ollama', 'aider'.",
    "claude": {
      "model": "auto",
      "_comment_model": "'auto' lets the CLI pick the best model; use claude-sonnet-4-6 for explicit control"
    },
    "ollama": {
      "model": "qwen2.5-coder:7b",
      "host": "http://localhost:11434"
    },
    "aider": {
      "model": ""
    }
  },
  "smtp": {
    "host": "smtp.mail.com",
    "port": 587,
    "username": "YOUR_GMAIL_ADDRESS@gmail.com",
    "password": "YOUR_GMAIL_APP_PASSWORD",
    "from_email": "YOUR_GMAIL_ADDRESS@gmail.com",
    "to_email": "YOUR_EMAIL@mail.com"
  },
  "repositories": [
    {
      "repo": "github_username/repo_name",
      "name": "RepoName",
      "local_path": "C:/path/to/local/repo_name"
    },
    {
      "repo": "github_username/repo_name2",
      "name": "RepoName2",
      "local_path": "C:/path/to/local/repo_name2"
    }
  ]
}
